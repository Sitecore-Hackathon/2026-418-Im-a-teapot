{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "shadcdn": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "shadcn@latest",
                "mcp"
            ],
        },
        "Sitecore Documentation": {
            "type": "remote",
            "url": "https://doc.sitecore.com/mcp",
            "headers": {
                "User-Agent": "sitecore-mcp-client/1.0"
            }
        }
    }
}